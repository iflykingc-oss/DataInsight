# ============================================================
# DataInsight — Required Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# JWT — REQUIRED. Must be at least 32 random characters.
# Generate with: openssl rand -base64 32
JWT_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Initial admin account (used on first boot)
INIT_ADMIN_USERNAME=
INIT_ADMIN_PASSWORD=

# Registration — set to 'true' to allow public self-registration
ENABLE_REGISTRATION=false

# PayPal (leave blank to disable PayPal payments)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SANDBOX=true
# Your PayPal Webhook ID from the PayPal developer dashboard
PAYPAL_WEBHOOK_ID=

# Creem (leave blank to disable Creem payments)
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_TEST_MODE=true
CREEM_PRO_MONTHLY_PRODUCT_ID=
CREEM_PRO_YEARLY_PRODUCT_ID=
CREEM_BUSINESS_MONTHLY_PRODUCT_ID=
CREEM_BUSINESS_YEARLY_PRODUCT_ID=

# Pricing plans JSON (optional — defaults are used if not set)
# PRICING_PLANS=

# App domain (used for payment redirect URLs)
NEXT_PUBLIC_APP_URL=https://yourdomain.com
